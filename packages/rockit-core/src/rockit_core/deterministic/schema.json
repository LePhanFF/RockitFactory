{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "rockit-framework Snapshot Schema",
  "description": "Validates structure of generated JSON snapshots",
  "type": "object",
  "required": [
    "session_date",
    "current_et_time",
    "premarket",
    "intraday",
    "core_confluences"
  ],
  "properties": {
    "session_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Session date in YYYY-MM-DD format"
    },
    "current_et_time": {
      "type": "string",
      "pattern": "^\\d{2}:\\d{2}$",
      "description": "Current time in HH:MM format (ET)"
    },
    "premarket": {
      "type": "object",
      "description": "Pre-market context data"
    },
    "intraday": {
      "type": "object",
      "required": ["ib", "volume_profile", "tpo_profile", "dpoc_migration"],
      "properties": {
        "ib": {
          "type": "object",
          "description": "Initial Balance data"
        },
        "volume_profile": {
          "type": "object",
          "description": "Volume profile analysis"
        },
        "tpo_profile": {
          "type": "object",
          "description": "TPO profile analysis"
        },
        "dpoc_migration": {
          "type": "object",
          "description": "DPOC migration analysis"
        },
        "wick_parade": {
          "type": "object",
          "description": "Wick parade analysis"
        },
        "ninety_min_pd_arrays": {
          "type": "object",
          "description": "90-minute pivot levels"
        },
        "fvg_detection": {
          "type": "object",
          "description": "Fair Value Gap detection"
        },
        "core_confluences": {
          "type": "object",
          "description": "Pre-computed confluence signals"
        },
        "trend_analysis": {
          "type": "object",
          "description": "Trend confirmation and strength analysis"
        },
        "cri_readiness": {
          "type": "object",
          "description": "Contextual Readiness Index"
        }
      },
      "additionalProperties": true
    },
    "core_confluences": {
      "type": "object",
      "properties": {
        "ib_acceptance": {
          "type": "object",
          "required": ["close_above_ibh", "close_below_ibl"]
        },
        "dpoc_vs_ib": {
          "type": "object",
          "required": ["dpoc_above_ibh", "dpoc_below_ibl"]
        },
        "dpoc_compression": {
          "type": "object",
          "required": ["compressing_against_vah", "compressing_against_val"]
        },
        "price_location": {
          "type": "object",
          "required": ["in_upper_third", "in_lower_third", "in_middle", "location_label"]
        },
        "tpo_signals": {
          "type": "object",
          "required": ["single_prints_above", "single_prints_below"]
        },
        "migration": {
          "type": "object",
          "required": ["significant_up", "significant_down"]
        }
      },
      "additionalProperties": true
    },
    "inference": {
      "type": "object",
      "description": "Decision engine output"
    }
  },
  "additionalProperties": true
}
